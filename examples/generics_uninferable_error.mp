// 不可推断的泛型：函数返回类型参数 T，但调用处没有提供任何
// 能推断出 T 的实参（既无涡轮鱼显式指定，也无位置实参可推导），
// 因此类型检查 / 单态化阶段必须报错，而不是退化成「鸭子类型」。
//
// 注意：函数体通过自我递归返回 T 来通过「函数体类型检查」，
// 真正要触发的是「调用处无法推断 T」这一静态约束。

fn f<T>() -> T {
    return f();
}

fn main() -> int {
    // 调用处无法推断 T：必须显式给出涡轮鱼 `f::<int>()`，
    // 否则编译器应拒绝（不允许鸭子类型）。
    let _x = f();
    return 0;
}
